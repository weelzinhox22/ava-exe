{
  "name": "ava-automacao",
  "version": "1.1.8",
  "description": "Automação de questionário AVA Kroton com Playwright + Groq SDK",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "prebuild": "node build.js",
    "build:win": "npm run prebuild && electron-builder --win",
    "dist": "npm run prebuild && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.studiooryon.ava",
    "productName": "Studio Oryon",
    "copyright": "Copyright © 2026 Studio Oryon",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "uninstallDisplayName": "Studio Oryon Uninstaller",
      "artifactName": "Studio_Oryon_Setup_v${version}.${ext}"
    },
    "files": [
      "dist-main.js",
      "preload.js",
      "public/**/*",
      "package.json",
      "node_modules/playwright-core/**/*",
      "node_modules/@playwright/**/*",
      "!node_modules/.bin",
      "!node_modules/supabase",
      "!node_modules/supabase/**/*",
      "!supabase",
      "!.env*",
      "!**/*.map",
      "!**/*.md",
      "!**/*.ts",
      "!**/LICENSE",
      "!**/CHANGELOG*"
    ],
    "asarUnpack": [
      "node_modules/playwright-core/**/*"
    ],
    "extraMetadata": {
      "main": "dist-main.js"
    },
    "publish": {
      "provider": "github",
      "owner": "weelzinhox22",
      "repo": "ava-exe",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.1",
    "chalk": "^4.1.2",
    "dotenv": "^16.6.1",
    "electron-updater": "^6.3.9",
    "express": "^5.2.1",
    "groq-sdk": "^0.8.0",
    "node-machine-id": "^1.1.12",
    "playwright-core": "^1.58.2"
  },
  "devDependencies": {
    "cli-table3": "^0.6.5",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-store": "^8.1.0",
    "esbuild": "^0.27.4",
    "supabase": "^2.84.4"
  }
}